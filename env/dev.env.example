# ============================================================================
# LinkMind dev.env.example
# ----------------------------------------------------------------------------
# 이 파일은 commit 되는 placeholder 템플릿입니다.
# 실제 값은 `env/dev.env`에 채우세요. (dev.env는 .gitignore로 제외됨)
#
# 사용: cp env/dev.env.example env/dev.env  →  실제 값 채우기
# ============================================================================

# ─────────────────────────────────────────────────────────────
# Postgres (Docker compose service: postgres)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=linkmind
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=linkmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://linkmind:changeme_strong_password@postgres:5432/linkmind
# 로컬 FastAPI에서 호스트로 접근할 때:
DATABASE_URL_LOCAL=postgresql+asyncpg://linkmind:changeme_strong_password@localhost:5432/linkmind

# ─────────────────────────────────────────────────────────────
# Qdrant (Docker compose service: qdrant)
# ─────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_URL_LOCAL=http://localhost:6333
QDRANT_COLLECTION=linkmind_items

# ─────────────────────────────────────────────────────────────
# Embedding
# - EMBEDDING_BACKEND=local       : Python 내장 sentence-transformers (MVP)
# - EMBEDDING_BACKEND=tei         : Phase 2 — TEI 컨테이너 사용
# - EMBEDDING_BACKEND=ollama      : Ollama embedding endpoint 사용
# ─────────────────────────────────────────────────────────────
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
TEI_URL=http://tei:80           # Phase 2 활성화 시

# ─────────────────────────────────────────────────────────────
# LLM Providers (모두 선택. 키가 있는 provider만 동작)
# ─────────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai     # openai | claude | ollama
DEFAULT_LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Ollama (Docker compose service: ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest

# ─────────────────────────────────────────────────────────────
# OpenClaw (Frontend agent — 별도 설치/실행. LinkMind는 HTTP로 연동)
# ─────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:7890
OPENCLAW_API_KEY=

# ─────────────────────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────────────────────
# Slack export ZIP 경로 (bulk import용)
SLACK_EXPORT_PATH=/data/slack_export
# Slack Web API token (실시간 방식 쓸 때만)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────────
# Telegram
# - MVP에서는 직접 봇 만들지 않음 (OpenClaw extension이 처리)
# - LinkMind에서 fallback 봇을 켤 때만 토큰 필요
# ─────────────────────────────────────────────────────────────
TELEGRAM_INGEST_BOT_TOKEN=
TELEGRAM_INGEST_CHAT_ID=
TELEGRAM_QUERY_BOT_TOKEN=
TELEGRAM_QUERY_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# LinkMind API
# ─────────────────────────────────────────────────────────────
LINKMIND_HOST=0.0.0.0
LINKMIND_PORT=8000
LINKMIND_LOG_LEVEL=INFO
# 외부 client(OpenClaw)가 LinkMind 호출 시 검증할 API 키 (선택)
LINKMIND_API_KEY=

# ─────────────────────────────────────────────────────────────
# Storage (원본 파일/이미지 저장 — sVLL 학습용 보존)
# ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | minio (Phase 2)
STORAGE_LOCAL_PATH=./volumes/archive

# MinIO (Phase 2 활성화 시)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=linkmind

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
# 분석 결과(요약/태그) 버전 — 재학습/A-B 비교 추적용
ANALYSIS_PROMPT_VERSION=v1
