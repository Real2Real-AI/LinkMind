# ============================================================================
# LinkMind dev.env.example
# ----------------------------------------------------------------------------
# 이 파일은 commit 되는 placeholder 템플릿입니다.
# 실제 값은 `env/dev.env`에 채우세요. (dev.env는 .gitignore로 제외됨)
#
# 사용: cp env/dev.env.example env/dev.env  →  실제 값 채우기
# ============================================================================

# ─────────────────────────────────────────────────────────────
# Postgres (Docker compose service: postgres)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=linkmind
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=linkmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://linkmind:changeme_strong_password@postgres:5432/linkmind
# 로컬 FastAPI에서 호스트로 접근할 때:
DATABASE_URL_LOCAL=postgresql+asyncpg://linkmind:changeme_strong_password@localhost:5432/linkmind

# ─────────────────────────────────────────────────────────────
# Qdrant (Docker compose service: qdrant)
# ─────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_URL_LOCAL=http://localhost:6333
QDRANT_COLLECTION=linkmind_items

# ─────────────────────────────────────────────────────────────
# Embedding
# - EMBEDDING_BACKEND=local       : Python 내장 sentence-transformers (MVP)
# - EMBEDDING_BACKEND=tei         : Phase 2 — TEI 컨테이너 사용
# - EMBEDDING_BACKEND=ollama      : Ollama embedding endpoint 사용
# ─────────────────────────────────────────────────────────────
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
TEI_URL=http://tei:80           # Phase 2 활성화 시

# bge-m3 가 ~/.cache/huggingface/hub/ 에 받힌 후 1 로 두면 매 startup 마다 보내는
# Hugging Face Hub metadata HEAD 요청 + "HF_TOKEN 설정" 경고가 모두 사라진다.
# 첫 셋업 (모델 다운로드 전) 에는 0 으로 두거나 비워둘 것.
# get_settings() 가 이 값을 읽어 자동으로 process env 에 HF_HUB_OFFLINE 을 export.
HF_HUB_OFFLINE=1

# ─────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────
# 정책: env 에는 *시크릿* 과 *인프라 위치* 만. 어떤 provider / 어떤 모델 쓸지의
# 런타임 선호는 DB (app_settings) + UI Settings 탭 에서 관리. backend 가 첫
# 부팅할 때 DB 가 비어있으면 backend/config.py 의 Field default 가 fallback
# (현재 default: provider=ollama, ollama_model=qwen2.5:7b).
#
# 이전에는 DEFAULT_LLM_MODEL / OLLAMA_MODEL 등이 env 에 있었는데 제거됨:
#   - DEFAULT_LLM_MODEL : dead env (실제 LLM 호출에 안 쓰임). 완전 제거.
#   - OLLAMA_MODEL      : runtime_settings 가 DB → fallback config default 흐름
#                         으로 충분. UI 에서 변경 시 영구 저장.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Ollama (Docker compose service: ollama) — 인프라 위치만.
# - backend 가 compose 안에서 돌 때(IN_DOCKER=1):  http://ollama:11434
# - backend 가 호스트에서 돌 때(uvicorn 등):       http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL_LOCAL=http://localhost:11434

# ─────────────────────────────────────────────────────────────
# OpenClaw (Frontend agent — 별도 설치/실행. LinkMind는 HTTP로 연동)
# ─────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:7890
OPENCLAW_API_KEY=

# ─────────────────────────────────────────────────────────────
# Telegram inbox watcher (scripts/telegram_inbox_watcher.py — 별 daemon)
# ─────────────────────────────────────────────────────────────
# 셋업 (한 번):
#   1. https://my.telegram.org → 로그인 → 'API development tools' → 새 app 등록
#      → api_id (정수) + api_hash (32자) 발급
#   2. 채널 (LinkMind-Inbox) invite link 또는 채널명/peer id 를 TELEGRAM_INBOX_INVITE 에
#   3. bash scripts/telegram_inbox_watcher.sh — 첫 실행 시 전화번호 + SMS 코드 입력
#      → volumes/telegram/inbox.session 자동 생성, 다음부터는 그것만으로 동작
# CLAUDE.md §3: backend 안에 봇 코드 X — 이건 watcher daemon 이 scripts/ 안에서만.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=volumes/telegram/inbox.session
TELEGRAM_INBOX_INVITE=
# ingest 성공 시 채널의 그 메시지 자동 삭제 → 처리 안 된 것만 채널에 남음 (inbox
# 패턴). 로컬에서 운영할 때 'LinkMind 가 받았나' 확인 비용을 줄임. false 로 끄면
# 메시지 보존 (로그로만 확인). default true.
TELEGRAM_DELETE_AFTER_INGEST=true

# ─────────────────────────────────────────────────────────────
# Slack
# ----------------------------------------------------------------------------
# 토큰/쿠키 추출 절차는 docs/slack_setup.md 참고.
# 인증 자료는 slackdump 자체 캐시(~/.cache/slackdump/<alias>.bin)에도 보관됨 —
# LinkMind 백엔드(Phase 2) 가 Slack Web API 호출 또는 첨부 다운로드할 때
# 아래 환경변수를 읽음.
# ─────────────────────────────────────────────────────────────

# Export 결과물이 놓일 경로 (slackdump 가 -o 로 출력하는 곳)
SLACK_EXPORT_PATH=./archive/slack_export

# 워크스페이스 메타 (LinkMind 가 source_url 재구성/dedup 시 사용)
SLACK_TEAM_ID=
SLACK_WORKSPACE_NAME=
SLACK_WORKSPACE_DOMAIN=
SLACK_WORKSPACE_URL=

# User Token (xoxc-...) + d 쿠키 — Slack Web API 호출용 (둘은 한 쌍)
# 추출: DevTools Console → JSON.parse(localStorage.localConfig_v2).teams (xoxc)
# 추출: DevTools Application → Cookies → 'd' (xoxd, URL-encoded 그대로)
SLACK_USER_TOKEN=
SLACK_D_COOKIE=

# (선택) 공식 Slack Export 의 파일 다운로드 토큰 (xoxe-...)
# 공식 export ZIP 안의 비공개 파일 URL 에서 다운로드할 때만 필요 (?t=<이 값>).
# slackdump 를 쓰면 xoxc+cookie 로 모든 첨부 다운로드 가능 — 이건 사실상 불필요.
SLACK_EXPORT_FILE_TOKEN=

# Bot Token 방식 (실시간 webhook/Events API 쓸 때만 — 현재 미사용)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────────
# Telegram
# - MVP에서는 직접 봇 만들지 않음 (OpenClaw extension이 처리)
# - LinkMind에서 fallback 봇을 켤 때만 토큰 필요
# ─────────────────────────────────────────────────────────────
TELEGRAM_INGEST_BOT_TOKEN=
TELEGRAM_INGEST_CHAT_ID=
TELEGRAM_QUERY_BOT_TOKEN=
TELEGRAM_QUERY_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# LinkMind API
# ─────────────────────────────────────────────────────────────
LINKMIND_HOST=0.0.0.0
LINKMIND_PORT=8000
LINKMIND_LOG_LEVEL=INFO
# 외부 client(OpenClaw)가 LinkMind 호출 시 검증할 API 키 (선택)
LINKMIND_API_KEY=

# ─────────────────────────────────────────────────────────────
# Storage (원본 파일/이미지 저장 — sVLL 학습용 보존)
# ─────────────────────────────────────────────────────────────
# raw 파일 (PDF / DOCX / PPTX / 이미지 / 텔레그램 첨부 등) 저장 위치.
# - 기본: ./volumes/archive (프로젝트 디렉토리 안)
# - 큰 디스크로 옮기려면 절대경로:  STORAGE_LOCAL_PATH=/mnt/data/linkmind/archive
# - VOLUMES_ROOT (아래) 와 별개 — backend(host) 가 직접 쓰는 path.
STORAGE_BACKEND=local           # local | minio (Phase 2)
STORAGE_LOCAL_PATH=./volumes/archive

# MinIO (Phase 2 활성화 시)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=linkmind

# ─────────────────────────────────────────────────────────────
# Docker 컨테이너 영속 데이터 (Postgres / Qdrant / Ollama / OpenWebUI / MinIO / Redis)
# ─────────────────────────────────────────────────────────────
# docker compose 의 모든 bind mount 의 root 디렉토리.
# - 기본: ../volumes (compose/ 디렉토리 기준 → 프로젝트 루트의 volumes/)
# - 큰 디스크로 옮기려면 절대경로:  VOLUMES_ROOT=/mnt/data/linkmind/volumes
# - 한 변수만 바꾸면 postgres/qdrant/ollama/openwebui/minio/redis 의 데이터
#   디렉토리가 모두 그 아래로 이동.
# - **변경 시 기존 DB 데이터를 잃지 않으려면**: 컨테이너 stop → ../volumes 를
#   새 경로로 복사/이동 → VOLUMES_ROOT 설정 → 컨테이너 start.
#   (compose 가 NEW path/postgres 를 mount 하므로, 그 안에 옛 데이터 있어야 함)
VOLUMES_ROOT=../volumes

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
# 분석 결과(요약/태그) 버전 — 재학습/A-B 비교 추적용
ANALYSIS_PROMPT_VERSION=v1
